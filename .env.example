# Azure Foundry Configuration for Anthropic Claude
# Copy this file to .env and fill in your credentials
# cp .env.example .env

# Required: Azure Foundry endpoint URL
AZURE_FOUNDRY_ENDPOINT=https://your-azure-foundry-endpoint.azure.com

# Required: Azure Foundry API Key
AZURE_FOUNDRY_API_KEY=your-api-key-here

# Optional: Default Claude model to use
# Available models: claude-3-5-sonnet-20241022, claude-3-opus-20240229,
#                   claude-3-sonnet-20240229, claude-3-haiku-20240307
AZURE_FOUNDRY_MODEL=claude-3-5-sonnet-20241022

# Optional: Temperature for LLM responses (0.0 - 1.0)
# Lower = more deterministic, Higher = more creative
AZURE_FOUNDRY_TEMPERATURE=0.3

# Optional: Maximum tokens for LLM response
AZURE_FOUNDRY_MAX_TOKENS=4096
